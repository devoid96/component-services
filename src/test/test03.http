### ====================================================
### PARTE 3: POST INVALIDOS (400)
### ====================================================

### 22. POST CPU invalido (brand vacio)
POST http://localhost:8082/api/v1/component-service/cpus
Content-Type: application/json

{
	"brand": "",
	"model": "Ryzen 5 9600X",
	"price": 1299000,
	"socket": "AM5",
	"cores": 6,
	"threads": 12,
	"tdp": 105
}

###

### 23. POST GPU invalido (model vacio)
POST http://localhost:8082/api/v1/component-service/gpus
Content-Type: application/json

{
	"brand": "NVIDIA",
	"model": "",
	"price": 3499000,
	"vram": 12,
	"tdp": 220,
	"pcieVersion": "PCIe 4.0"
}

###

### 24. POST RAM invalido (price invalido)
POST http://localhost:8082/api/v1/component-service/rams
Content-Type: application/json

{
	"brand": "Corsair",
	"model": "Dominator Platinum",
	"price": -100,
	"type": "DDR5",
	"capacity": 32,
	"speed": 6200
}

###

### 25. POST Motherboard invalido (socket faltante)
POST http://localhost:8082/api/v1/component-service/motherboards
Content-Type: application/json

{
	"brand": "ASUS",
	"model": "TUF Gaming B650-Plus",
	"price": 999900,
	"ramType": "DDR5",
	"maxRam": 128,
	"pcieVersion": "PCIe 4.0"
}

###

### 26. POST PSU invalido (efficiency faltante)
POST http://localhost:8082/api/v1/component-service/psus
Content-Type: application/json

{
	"brand": "Seasonic",
	"model": "Focus GX-750",
	"price": 699900,
	"wattage": 750
}

###

